# .env.prod.example — template for the real .env.prod on the droplet
# Copy to .env.prod and fill in real values. Never commit .env.prod.

# Domain used by Caddy for TLS cert provisioning
DOMAIN=new.yourdomain.com

# Image tag override (defaults to 'latest' if unset)
# IMAGE_TAG=abc1234

# Database — DO Managed Postgres connection string
DATABASE_URL=postgresql://doadmin:CHANGEME@db-postgresql-xxx.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# App secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGEME_GENERATE_LONG_RANDOM_STRING

# DO Spaces (S3-compatible object storage)
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_KEY=CHANGEME
SPACES_SECRET=CHANGEME
SPACES_BUCKET=cns-tools-prod